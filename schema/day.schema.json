{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glean-mastery/schema/day.schema.json",
  "title": "Curriculum Day Frontmatter",
  "description": "Schema for the YAML frontmatter of every content/weeks/NN/day-NN.mdx file.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "week",
    "day",
    "level",
    "title",
    "theme",
    "objectives",
    "references",
    "nist_rmf",
    "quiz_ref",
    "status"
  ],
  "properties": {
    "week": { "type": "integer", "minimum": 1 },
    "day": { "type": "integer", "minimum": 1 },
    "level": { "type": "string", "enum": ["200", "300", "400", "500"] },
    "title": { "type": "string", "minLength": 4 },
    "theme": { "type": "string", "minLength": 4 },
    "duration_min": { "type": "integer", "minimum": 1 },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id"],
        "properties": {
          "source_id": { "type": "string", "minLength": 2 },
          "minutes": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "lab": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minutes": { "type": "integer", "minimum": 1 },
        "steps_ref": { "type": "boolean" }
      }
    },
    "working_example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified_against"],
      "properties": {
        "language": { "type": "string" },
        "verified_against": { "type": "string", "minLength": 2 }
      }
    },
    "case_study": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id"],
      "properties": {
        "source_id": { "type": "string", "minLength": 2 }
      }
    },
    "nist_rmf": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["GOVERN", "MAP", "MEASURE", "MANAGE"] }
    },
    "check_for_understanding": { "type": "string", "minLength": 4 },
    "quiz_ref": { "type": "string", "pattern": "^quiz-w[0-9]{2}$" },
    "status": { "type": "string", "enum": ["draft", "verified", "published"] }
  }
}
